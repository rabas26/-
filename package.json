{
  "name": "alkhokhah-gate-website",
  "version": "1.0.0",
  "description": "موقع مخطط بوابة الخوخة السكنية النموذجية - Al-Khokhah Gate Residential Model Scheme Website",
  "main": "index.html",
  "scripts": {
    "start": "live-server --port=3000 --open=/index.html",
    "build": "npm run minify-css && npm run minify-js",
    "minify-css": "cleancss -o dist/styles.min.css styles.css",
    "minify-js": "uglifyjs script.js enhancements.js config.js -o dist/script.min.js",
    "optimize-images": "imagemin images/* --out-dir=dist/images",
    "deploy": "npm run build && npm run optimize-images",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint *.js",
    "format": "prettier --write *.html *.css *.js",
    "serve": "http-server -p 8080 -c-1"
  },
  "keywords": [
    "real-estate",
    "yemen",
    "al-khokhah",
    "residential",
    "property",
    "investment",
    "الخوخة",
    "عقارات",
    "أراضي",
    "استثمار"
  ],
  "author": "مخطط بوابة الخوخة السكنية النموذجية",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alkhokhah-gate/website.git"
  },
  "bugs": {
    "url": "https://github.com/alkhokhah-gate/website/issues"
  },
  "homepage": "https://alkhokhah-gate.com",
  "devDependencies": {
    "live-server": "^1.2.2",
    "clean-css-cli": "^5.6.2",
    "uglify-js": "^3.17.4",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-svgo": "^10.0.1",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "swiper": "^10.3.1",
    "leaflet": "^1.9.4",
    "chart.js": "^4.4.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
